#!/bin/bash

# Git pre-push hook to automatically back up and upload the local database to B2 using Python tool directly
echo "------------------------------------------------------------"
echo "Git Pre-Push Hook: Starting database backup (Python)..."
echo "------------------------------------------------------------"

# Navigate to python app directory and run the script directly with python3
cd packages/python/procureiq-python

python3 scripts/db_b2.py backup && python3 scripts/db_b2.py upload

if [ $? -eq 0 ]; then
    echo "------------------------------------------------------------"
    echo "Git Pre-Push Hook: Database backup and upload completed successfully!"
    echo "Proceeding with Git push..."
    echo "------------------------------------------------------------"
    exit 0
else
    echo "------------------------------------------------------------"
    echo "Git Pre-Push Hook: Error: Database backup or upload failed!"
    echo "Aborting push to protect code/data sync."
    echo "------------------------------------------------------------"
    exit 1
fi
