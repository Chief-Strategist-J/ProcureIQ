#!/bin/bash
echo "------------------------------------------------------------"
echo "Git Post-Merge Hook: Syncing local database (Python)..."
echo "------------------------------------------------------------"
cd packages/python/procureiq-python
python3 scripts/db_b2.py download && python3 scripts/db_b2.py restore
if [ $? -eq 0 ]; then
    echo "------------------------------------------------------------"
    echo "Git Post-Merge Hook: Database successfully synced with B2!"
    echo "------------------------------------------------------------"
    exit 0
else
    echo "------------------------------------------------------------"
    echo "Git Post-Merge Hook: Warning: Database sync failed!"
    echo "------------------------------------------------------------"
    exit 1
fi
